{
	"private": true,
	"packageManager": "pnpm@10.18.2",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"postinstall": "nuxt prepare",
		"lint": "eslint . && prettier .",
		"lint:fix": "eslint . --fix && prettier . --write",
		"typecheck": "nuxt typecheck"
	},
	"devDependencies": {
		"@iconify-json/ri": "^1.2.6",
		"@nuxtjs/google-fonts": "3.2.0",
		"@so1ve/eslint-config": "^3.9.1",
		"@so1ve/prettier-config": "^3.9.1",
		"@unocss/nuxt": "^66.5.3",
		"@unocss/reset": "^66.5.3",
		"eslint": "^9.37.0",
		"nuxt": "4.1.3",
		"prettier": "^3.6.2",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"vite",
				"webpack"
			]
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"unrs-resolver"
		]
	}
}
